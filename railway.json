{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm run start",
    "restartPolicyMaxRetries": 5,
    "databases": [
      {
        "name": "postgres",
        "engine": "postgresql"
      }
    ]
  }
}
